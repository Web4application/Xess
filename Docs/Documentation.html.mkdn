import h5py
def update_ui_dna(feature_name, weight_change):
    with h5py.File("app_dna.h5", "a") as f:
        if "ui_weights" not in f:
            # Store features like 'btn_size', 'bg_color', 'font_scale'
            dt = h5py.special_dtype(vlen=str)
            dset = f.create_dataset("ui_weights", (10,), dtype='f')
            dset.attrs["feature_map"] = ["search_bar", "log_btn", "theme_dark"]
        
        # Adjust the 'importance' of a feature based on usage
        weights = f["ui_weights"]
        weights[0] += weight_change # e.g., Increasing search bar prominence

